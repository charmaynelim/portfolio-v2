---
import BaseLayout from './BaseLayout.astro';
import ContentContainer from '../components/global/ContentContainer.astro';
import StickyHeader from '../components/global/StickyHeader.astro';

interface Props {
  title?: string;
  description?: string;
  backHref?: string;
}

const { title, description, backHref = '/' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <StickyHeader backHref={backHref} />
  <ContentContainer>
    <slot />
  </ContentContainer>
</BaseLayout>
