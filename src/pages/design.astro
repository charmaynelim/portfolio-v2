---
import DesignLayout from '../layouts/DesignLayout.astro';
import { Image } from 'astro:assets';
import homepage from '../assets/design/homepage.png';
import mobile from '../assets/design/mobile.png';
import cardmaximiser from '../assets/design/cardmaximiser.png';
---

<DesignLayout title="Designing at HeyMax - charmayne" description="HeyMax design case study">
  <div class="design-text">
    <p class="text-metadata" style="margin-bottom: 8px;">Founding Designer · 2023 - 2025</p>
    <h1 class="text-post-title" style="margin-bottom: 16px;">Launching HeyMax (web & mobile app)</h1>
    <p class="text-bio">0 to 1 design of HeyMax's flagship travel rewards platform. Optimised for impact over polish.</p>
  </div>

  <div class="design-image-full">
    <Image src={homepage} alt="HeyMax homepage design" widths={[1200, 1920, 2560, 3750]} sizes="calc(100vw - 88px)" quality={90} loading="eager" />
  </div>

  <div class="design-text">
    <p class="text-post-title" style="margin-bottom: 8px;">Section title placeholder</p>
    <p class="text-bio">Section description placeholder. Replace with real content.</p>
  </div>

  <div class="design-image-full">
    <Image src={mobile} alt="HeyMax mobile app design" widths={[1200, 1920, 2560, 3750]} sizes="calc(100vw - 88px)" quality={90} loading="lazy" />
  </div>

  <div class="design-text">
    <p class="text-post-title" style="margin-bottom: 8px;">Card Maximiser</p>
    <p class="text-bio">First real-time card spend and rewards tracker in partnership with Visa. Read about it here</p>
  </div>

  <div class="design-image-full">
    <Image src={cardmaximiser} alt="HeyMax Card Maximiser feature" widths={[1200, 1920, 2560, 3756]} sizes="calc(100vw - 88px)" quality={90} loading="lazy" />
  </div>

  <div class="design-text">
    <p class="text-post-title" style="margin-bottom: 8px;">Section title placeholder</p>
    <p class="text-bio">Section description placeholder. Replace with real content.</p>
  </div>
</DesignLayout>
