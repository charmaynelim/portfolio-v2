---
// ProjectListItem displays a single clickable project row with optional icon
interface Props {
  title: string;
  href: string;
  icon?: string;
  external?: boolean;
  subtitle?: string;
}

const { title, href, icon, external, subtitle } = Astro.props;
const externalAttrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a href={href} class:list={["project-list-item", "text-project-link", { external }]} {...externalAttrs}>
  {icon && icon.trim() && <img src={icon} alt="" class="project-icon" />}
  <span class="project-title">{title}{subtitle && <span class="project-subtitle">{subtitle}</span>}{external && <img src="/icons/external-arrow.svg" alt="" class="external-icon" />}</span>
</a>

<style>
  .project-list-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 24px 0;
    text-decoration: none;
  }

  .project-icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .project-title {
    flex: 1;
    min-width: 0;
    overflow-wrap: break-word;
  }

  .project-subtitle {
    margin-left: 10px;
    color: var(--color-text-tertiary);
  }

  .external-icon {
    width: 20px;
    height: 20px;
    display: inline;
    vertical-align: middle;
    position: relative;
    top: -1px;
    margin-left: 8px;
  }

  @media (max-width: 767px) {
    .project-list-item {
      gap: 12px;
    }
  }
</style>
