---
import ProjectListItem from './ProjectListItem.astro';
import HorizontalDivider from '../global/HorizontalDivider.astro';

// ProjectList renders list of project/blog links with dividers
interface Props {
  projects: {
    title: string;
    href: string;
    icon?: string;
    external?: boolean;
    subtitle?: string;
    hidden?: boolean; // Set to true in homepage.json to hide a row; remove to re-enable
  }[];
}

const { projects } = Astro.props;
const visibleProjects = projects.filter((p) => !p.hidden);
---

<nav class="project-list">
  {visibleProjects.map((project, index) => (
    <>
      {index > 0 && <HorizontalDivider />}
      <ProjectListItem title={project.title} href={project.href} icon={project.icon} external={project.external} subtitle={project.subtitle} />
    </>
  ))}
  <HorizontalDivider />
</nav>

<style>
  .project-list {
    margin-bottom: var(--spacing-section);
  }

  @media (max-width: 767px) {
    .project-list {
      margin-bottom: var(--spacing-section-mobile);
    }
  }
</style>
